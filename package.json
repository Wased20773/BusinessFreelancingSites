{
  "name": "business-freelancer-platform",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/platform",
    "apps/businesses/*",
    "packages/*"
  ],
  "scripts": {
    "dev:platform": "npm run dev --workspace=platform -- --port 3000",
    "dev:tacos-el-guero": "npm run dev --workspace=tacos-el-guero -- --port 3001",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present"
  }
}